<?xml version="1.0" encoding="UTF-8"?>
<pythonPanelDocument>
  <interface name="houdini_agent" label="Houdini Agent" icon="MISC_python" help_url="">
    <script><![CDATA[
import sys
import os

# Add repo root to path so bridge module can be imported
_repo_root = os.path.join(os.path.dirname(os.path.abspath(__file__)), "..")
_repo_root = os.path.normpath(_repo_root)
if _repo_root not in sys.path:
    sys.path.insert(0, _repo_root)

# Also add panels/ so the panel module can be found
_panels_dir = os.path.dirname(os.path.abspath(__file__))
if _panels_dir not in sys.path:
    sys.path.insert(0, _panels_dir)

from houdini_agent_panel import HoudiniAgentPanel

def onCreateInterface():
    return HoudiniAgentPanel()
]]></script>
    <includeInPaneTabMenu>true</includeInPaneTabMenu>
    <includeInToolbarMenu>false</includeInToolbarMenu>
    <help><![CDATA[Start and stop the Houdini Agent bridge server. The bridge allows Claude Code to control Houdini over HTTP.]]></help>
  </interface>
</pythonPanelDocument>
